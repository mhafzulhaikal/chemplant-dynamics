# ChemPlant Dynamics — Environment Variables
# Copy this file to .env and fill in your values before running Docker Compose.
# Never commit .env to version control.

# ── App Secret ────────────────────────────────────────────────────────────────
# Used by NiceGUI for session storage signing.
# Generate a strong random value: python -c "import secrets; print(secrets.token_hex(32))"
STORAGE_SECRET=change-me-to-a-strong-random-secret
